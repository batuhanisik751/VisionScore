# ── Ollama (AI Feedback) ──────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llava

# ── Supabase (Cloud Storage) ─────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── API Server ───────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Models ───────────────────────────────────────────────────
# Directory for downloaded model weights (NIMA, YOLOv8)
MODEL_DIR=~/.visionscore/models
# Path to a custom fine-tuned NIMA model (from `visionscore train`)
CUSTOM_MODEL_PATH=

# ── Image Processing ────────────────────────────────────────
MAX_IMAGE_SIZE=1024
MAX_UPLOAD_MB=20
# PyTorch device: auto | cpu | cuda | mps
DEVICE=auto

# ── Output ───────────────────────────────────────────────────
# Default output format: text | json | markdown | csv
OUTPUT_FORMAT=text

# ── Plugins ──────────────────────────────────────────────────
# Enable bundled plugins (e.g. Instagram Readiness)
ENABLE_BUNDLED_PLUGINS=false
# Directory for user-installed plugin .py files
PLUGIN_DIR=~/.visionscore/plugins
